{
  "name": "midnite-shadow-online",
  "version": "1.0.12",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build && node --use-system-ca ./scripts/generate-og-images.mjs dist",
    "build:local": "npm run build && node ./scripts/check-accessible-names.mjs dist",
    "og:generate": "astro build && node --use-system-ca ./scripts/generate-og-images.mjs --force dist",
    "preview": "astro preview",
    "watch": "node ./scripts/watch.mjs",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "release:patch": "npm version patch --no-git-tag-version"
  },
  "dependencies": {
    "@astrojs/check": "latest",
    "@astrojs/cloudflare": "^13.6.1",
    "@astrojs/mdx": "^6.0.2",
    "@resvg/resvg-wasm": "^2.6.2",
    "astro": "latest",
    "satori": "^0.26.0",
    "typescript": "latest"
  },
  "overrides": {
    "yaml-language-server": {
      "yaml": "^2.9.0"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.5"
  }
}
