---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Gaming | MidNiteShadow Online">
  <section class="hero">
    <img class="hero-bg" src="/assets/images/placeholder.webp" alt="" /><div
      class="container"
    >
      <p class="eyebrow">Gaming</p><h1>
        Online games, fandoms and communities.
      </h1><p class="lede">
        A broad home for Star Trek Online, sci-fi gaming, community spaces,
        screenshots, tools and gaming-related experiments.
      </p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Game spaces</p>
      <h1>Current games and connected projects</h1>
      <p class="lede">
        Browse the main online games that I am currently involved with.
      </p>
      <div class="grid" style="margin-top: 40px;">
        <article class="card large post-card">
          <img
            class="project-image"
            src="/assets/images/placeholder.webp"
            alt=""
          />
          <h3><a href="/gaming/star-trek-online/">Star Trek Online</a></h3>
          <p>
            I started playing Star Trek Online in 2011, and since then, I've
            been involved in podcasting, community events, forum moderating, and
            the development of online tools.
          </p>
          <a class="button read-more-cta" href="/gaming/star-trek-online/"
            >Read more</a
          >
          <div class="card-tags">
            <span class="tag">Star Trek</span>
            <span class="tag">PC</span>
            <span class="tag">Xbox</span>
            <span class="tag">PlayStation</span>
            <span class="tag">MMO</span>
          </div>
        </article>
        <article class="card large post-card">
          <img
            class="project-image"
            src="/assets/images/placeholder.webp"
            alt=""
          />
          <h3>
            <a href="/gaming/star-trek-fleet-command/"
              >Star Trek Fleet Command</a
            >
          </h3>
          <p>
            I began playing Star Trek Fleet Command in 2018, where I have been
            participating in community play, progression planning, alliance
            management, and related activities.
          </p>
          <a
            class="button read-more-cta"
            href="/gaming/star-trek-fleet-command/">Read more</a
          >
          <div class="card-tags">
            <span class="tag">Star Trek</span>
            <span class="tag">Mobile</span>
            <span class="tag">PC</span>
          </div>
        </article>
        <article class="card large post-card">
          <img
            class="project-image"
            src="/assets/images/placeholder.webp"
            alt=""
          />
          <h3><a href="/dnd/">Dungeons &amp; Dragons</a></h3>
          <p>
            I did not start playing D&amp;D until the summer of 2025, where I
            have only played online using virtual tabletops. I quickly became
            involved in character creation, worldbuilding, and modding APIs.
          </p>
          <a class="button read-more-cta" href="/dnd/">Read more</a>
          <div class="card-tags">
            <span class="tag">Virtual Tabletops</span>
            <span class="tag">Campaigns</span>
            <span class="tag">Roll20</span>
            <span class="tag">APIs</span>
            <span class="tag">Modding</span>
            <span class="tag">Creative</span>
          </div>
        </article>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Network links</p>
      <h2>Gaming network links</h2>
      <p class="lede">
        Quick links to current gaming hubs, project spaces, and connected
        sections across the site.
      </p>
      <div class="grid" style="margin-top: 24px;">
        <article class="card large post-card">
          <h3><a href="https://startrekonline.info">STO Info</a></h3>
          <p>
            The live community app for Star Trek Online players, covering
            account and character tracking plus a growing feature roadmap.
          </p>
          <a class="button read-more-cta" href="https://startrekonline.info"
            >Open site</a
          >
        </article>
        <article class="card large post-card">
          <h3><a href="/projects/sto-info/">STO Info project</a></h3>
          <p>
            Project notes, development context, and roadmap-oriented information
            for the Star Trek Online toolset.
          </p>
          <a class="button read-more-cta" href="/projects/sto-info/"
            >Read more</a
          >
        </article>
        <article class="card large post-card">
          <h3><a href="/projects/roll20-mods/">Roll20 Mods</a></h3>
          <p>
            Tabletop tooling that supports RPG play with automation, token
            utilities, and related project documentation.
          </p>
          <a class="button read-more-cta" href="/projects/roll20-mods/"
            >Read more</a
          >
        </article>
        <article class="card large post-card">
          <h3><a href="/projects/podcasting/">Podcasting project</a></h3>
          <p>
            Media and production work tied to community output, show planning,
            and wider geek-network activity.
          </p>
          <a class="button read-more-cta" href="/projects/podcasting/"
            >Read more</a
          >
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
