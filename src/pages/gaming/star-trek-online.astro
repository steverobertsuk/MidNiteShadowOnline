---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import placeholderImage from "../../assets/images/placeholder.webp";
import { getImageLoadingPolicy } from "../../lib/mediaPriority";

const heroImagePolicy = getImageLoadingPolicy("hero");
---

<BaseLayout
  title="Star Trek Online | Gaming | MidNiteShadow Online"
  description="Gaming notes and links for Star Trek Online."
>
  <section class="hero">
    <Image class="hero-bg" src={placeholderImage} alt="" loading={heroImagePolicy.loading} fetchpriority={heroImagePolicy.fetchpriority} decoding={heroImagePolicy.decoding} />
    <div class="container">
      <p class="eyebrow">Gaming</p>
      <h1>Star Trek Online</h1>
      <p class="lede">
        A hub for Star Trek Online interests, related community work, and links
        into the STO Info project.
      </p>
      <div class="meta">
        <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> MMO</span><span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> Star Trek</span>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container prose">
      <h2>Overview</h2>
      <p>
        This page is the landing space for broader Star Trek Online coverage,
        including gameplay interests, community context, and related development
        work.
      </p>
      <h2>Connected project</h2>
      <p>
        The main supporting project for this space is <a
          href="/projects/sto-info/">STO Info</a
        >, which tracks the dedicated app and its ongoing roadmap.
      </p>
    </div>
  </section>
</BaseLayout>
