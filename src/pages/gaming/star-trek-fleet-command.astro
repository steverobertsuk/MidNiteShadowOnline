---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import placeholderImage from "../../assets/images/placeholder.webp";
---

<BaseLayout
  title="Star Trek Fleet Command | Gaming | MidNiteShadow Online"
  description="Gaming notes and links for Star Trek Fleet Command."
>
  <section class="hero">
    <Image class="hero-bg" src={placeholderImage} alt="" loading="eager" fetchpriority="high" />
    <div class="container">
      <p class="eyebrow">Gaming</p>
      <h1>Star Trek Fleet Command</h1>
      <p class="lede">
        A home for Fleet Command notes, progression ideas, and future guides or
        supporting resources.
      </p>
      <div class="meta">
        <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> Mobile</span><span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> Star Trek</span>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container prose">
      <h2>Overview</h2>
      <p>
        This page is set up for Fleet Command notes, fleet coordination ideas,
        and any future guides that grow out of active play.
      </p>
      <h2>Planning space</h2>
      <p>
        Use it to track useful strategy references, faction progression notes,
        event priorities, and community-facing resources as they are added.
      </p>
    </div>
  </section>
</BaseLayout>
