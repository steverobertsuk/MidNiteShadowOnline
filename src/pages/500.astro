---
import BaseLayout from "../layouts/BaseLayout.astro";
import AlertNotice from "../components/AlertNotice.astro";
import Hero from "../components/Hero.astro";
import placeholderImage from "../assets/images/placeholder.webp";
---
<BaseLayout
  title="500 — Server Error | MidNite Shadow Online"
  description="An unexpected server error occurred."
>
  <Hero
    eyebrow="Error 500"
    title="Server Error"
    lede="Something went wrong in the arcane machinery - an unexpected error has occurred."
    heroImage={placeholderImage}
    heroImageAlt="Arcane placeholder image"
  />
  <section class="section">
    <div class="container prose">
      <AlertNotice variant="error" title="Internal Server Error">
        <p>
          The server encountered an unexpected condition. This is not your fault.
          Please try again in a moment, or return to the home page.
        </p>
      </AlertNotice>
      <p>
        <a href="/" class="button primary">
          <i class="fa-solid fa-house" aria-hidden="true"></i> Return Home
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
