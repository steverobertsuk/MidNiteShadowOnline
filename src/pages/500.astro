---
import BaseLayout from '../layouts/BaseLayout.astro';
import AlertNotice from '../components/AlertNotice.astro';
import Hero from '../components/Hero.astro';
import profileImage from '../assets/images/mns7_profile.webp';
---

<BaseLayout
  title="500 — Server Error | MidNite Shadow Online"
  description="An unexpected server error occurred."
>
  <Hero
    eyebrow="Error 500"
    title="Server Error"
    lede="Something went wrong in the arcane machinery - an unexpected error has occurred."
    heroImage={profileImage}
    heroImageAlt="MidNite Shadow profile image"
  />
  <section class="section">
    <div class="container prose">
      <AlertNotice variant="error" title="Internal Server Error">
        <p>
          The server encountered an unexpected condition. This is not your fault. Please try again
          in a moment, or return to the home page.
        </p>
      </AlertNotice>
      <!-- Cloudflare replaces this token with its diagnostic box when this page
           is served from the zone's "5XX Errors" custom error page slot. -->
      <div class="cf-error-details">::CLOUDFLARE_ERROR_500S_BOX::</div>
      <p>
        <a href="/" class="button primary">
          <i class="fa-solid fa-house" aria-hidden="true"></i> Return Home
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
