---
import BaseLayout from "../layouts/BaseLayout.astro";
import AlertNotice from "../components/AlertNotice.astro";
import Hero from "../components/Hero.astro";
import placeholderImage from "../assets/images/placeholder.webp";
---
<BaseLayout
  title="404 — Page Not Found | MidNite Shadow Online"
  description="The page you were looking for could not be found."
>
  <Hero
    eyebrow="Error 404"
    title="Page Not Found"
    lede="The path you sought has faded into shadow - this page does not exist."
    heroImage={placeholderImage}
    heroImageAlt="Arcane placeholder image"
  />
  <section class="section">
    <div class="container prose">
      <AlertNotice variant="error" title="Not Found">
        <p>
          No content was found at this location. The page may have been moved,
          deleted, or the URL may contain a typo.
        </p>
      </AlertNotice>
      <p>
        <a href="/" class="button primary">
          <i class="fa-solid fa-house" aria-hidden="true"></i> Return Home
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
