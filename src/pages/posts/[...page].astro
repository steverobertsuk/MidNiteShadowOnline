---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import { formatPostDate, postIdToSlug, toSlug } from '../../lib/postCategory';

export async function getStaticPaths({ paginate }) {
  const allPosts = (await getCollection('posts')).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );
  const categories = [...new Set(allPosts.map((p) => p.data.category))].sort().map((name) => ({ name, slug: toSlug(name) }));
  return paginate(allPosts, { pageSize: 6, props: { categories } });
}

const { page, categories } = Astro.props;
---

<BaseLayout title={page.currentPage === 1 ? 'Posts | MidNiteShadow Online' : `Posts — Page ${page.currentPage} | MidNiteShadow Online`}>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Posts</p>
      <h1>News, Updates and Releases</h1>
      <p class="lede">
        A chronological feed of site posts drawn from Roll20, STO Info, podcasts
        and more.
      </p>
      <CategoryFilter categories={categories} />
      <div class="grid">
        {
          page.data.map((post) => (
            <article class="card large post-card">
              <h3>
                <a href={`/posts/${postIdToSlug(post.id)}/`}>
                  {post.data.title}
                </a>
              </h3>
              <div class="post-meta-inline">
                <time class="post-date" datetime={post.data.date.toISOString()}>
                  <i class="fa-regular fa-calendar" aria-hidden="true"></i> Posted: {formatPostDate(post.data.date)}
                </time>
                <span class="post-meta-separator">•</span>
                <a
                  class="category-meta-link"
                  href={`/posts/category/${toSlug(post.data.category)}/`}
                >
                  <i class="fa-solid fa-folder-open" aria-hidden="true"></i> {post.data.category}
                </a>
              </div>
              <p>{post.data.summary}</p>
              <a
                class="button read-more-cta"
                href={`/posts/${postIdToSlug(post.id)}/`}
              >Read more <i class="fa-solid fa-angles-right" aria-hidden="true"></i></a>
              {post.data.tags.length > 0 && (
                <div class="card-tags">
                  {post.data.tags.map((tag) => (
                    <a class="tag tag-cta" href={`/posts/tag/${toSlug(tag)}/`}>
                      <i class="fa-solid fa-tag" aria-hidden="true"></i> {tag}
                    </a>
                  ))}
                </div>
              )}
            </article>
          ))
        }
      </div>
      {page.lastPage > 1 && (
        <nav class="pagination" aria-label="Post pagination">
          <a
            class:list={['pagination-btn', { disabled: !page.url.prev }]}
            href={page.url.prev ?? '#'}
            aria-disabled={!page.url.prev ? 'true' : undefined}
            tabindex={!page.url.prev ? -1 : undefined}
          >
            <i class="fa-solid fa-angles-left" aria-hidden="true"></i> Previous
          </a>
          <div class="pagination-pages">
            {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((num) => (
              <a
                class:list={['pagination-page', { active: num === page.currentPage }]}
                href={num === 1 ? '/posts/' : `/posts/${num}/`}
                aria-current={num === page.currentPage ? 'page' : undefined}
              >
                {num}
              </a>
            ))}
          </div>
          <a
            class:list={['pagination-btn', { disabled: !page.url.next }]}
            href={page.url.next ?? '#'}
            aria-disabled={!page.url.next ? 'true' : undefined}
            tabindex={!page.url.next ? -1 : undefined}
          >
            Next <i class="fa-solid fa-angles-right" aria-hidden="true"></i>
          </a>
        </nav>
      )}
    </div>
  </section>
</BaseLayout>
