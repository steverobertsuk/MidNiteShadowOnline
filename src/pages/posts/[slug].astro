---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatPostDate, postIdToSlug, toSlug } from '../../lib/postCategory';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort(
    (a, b) => a.data.date.getTime() - b.data.date.getTime(),
  );
  return posts.map((post, index) => ({
    params: { slug: postIdToSlug(post.id) },
    props: {
      post,
      prev: index > 0 ? posts[index - 1] : null,
      next: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}
const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | MidNiteShadow Online`}
  description={post.data.summary}
>
  <section class="section">
    <div class="container post-layout">
      <article class="prose post-content">
        <h1>{post.data.title}</h1>
        <p class="lede">{post.data.summary}</p>
        {
          post.data.hero && (
            <Image
              class="post-hero-image"
              src={post.data.hero}
              alt={post.data.heroAlt ?? post.data.title}
              loading="eager"
              fetchpriority="high"
            />
          )
        }
        <Content />
      </article>
      <aside class="post-details-box" aria-label="Post details">
        <p class="post-details-title">Post details</p>
        <div class="post-details-block">
          <p class="post-details-label post-details-label-inline">
            <i class="fa-regular fa-calendar" aria-hidden="true"></i> Posted:
            <span class="post-details-date">
              <time datetime={post.data.date.toISOString()}>
                {formatPostDate(post.data.date)}
              </time>
            </span>
          </p>
        </div>
        <div class="post-details-block">
          <p class="post-details-label"><i class="fa-solid fa-folder-open" aria-hidden="true"></i> Category</p>
          <a
            class="tag category-cta"
            href={`/posts/category/${toSlug(post.data.category)}/`}
          >
            {post.data.category}
          </a>
        </div>
        {
          post.data.tags.length > 0 && (
            <div class="post-details-block">
              <p class="post-details-label"><i class="fa-solid fa-tag" aria-hidden="true"></i> Tags</p>
              <div class="post-details-tags">
                {post.data.tags.map((tag) => (
                  <a class="tag tag-cta" href={`/posts/tag/${toSlug(tag)}/`}>
                    <i class="fa-solid fa-tag" aria-hidden="true"></i> {tag}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </aside>
    </div>
    {(prev || next) && (
      <nav class="post-nav" aria-label="Post navigation">
        <div class="container">
          <div class="post-nav-inner">
            <div class="post-nav-slot post-nav-prev">
              {prev && (
                <a class="post-nav-link" href={`/posts/${postIdToSlug(prev.id)}/`}>
                  <span class="post-nav-dir"><i class="fa-solid fa-angles-left" aria-hidden="true"></i> Previous</span>
                  <span class="post-nav-title">{prev.data.title}</span>
                </a>
              )}
            </div>
            <div class="post-nav-slot post-nav-home">
              <a class="post-nav-link post-nav-home-link" href="/posts/">
                <i class="fa-solid fa-newspaper" aria-hidden="true"></i>
                <span>All posts</span>
              </a>
            </div>
            <div class="post-nav-slot post-nav-next">
              {next && (
                <a class="post-nav-link" href={`/posts/${postIdToSlug(next.id)}/`}>
                  <span class="post-nav-dir">Next <i class="fa-solid fa-angles-right" aria-hidden="true"></i></span>
                  <span class="post-nav-title">{next.data.title}</span>
                </a>
              )}
            </div>
          </div>
        </div>
      </nav>
    )}
  </section>
</BaseLayout>
