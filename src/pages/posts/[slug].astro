---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { formatPostDate, postIdToSlug, toSlug } from '../../lib/postCategory';
import { FALLBACK_SITE } from '../../lib/site';
import { blogPostingGraph } from '../../lib/structuredData';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort(
    (a, b) => a.data.date.getTime() - b.data.date.getTime()
  );
  return posts.map((post, index) => ({
    params: { slug: postIdToSlug(post.id) },
    props: {
      post,
      prev: index > 0 ? posts[index - 1] : null,
      next: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}
const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const siteBase = Astro.site ?? FALLBACK_SITE;
const jsonLd = blogPostingGraph(siteBase, {
  url: new URL(`/posts/${postIdToSlug(post.id)}/`, siteBase).href,
  title: post.data.title,
  summary: post.data.summary,
  datePublished: post.data.date,
  category: post.data.category,
  tags: post.data.tags,
});
---

<BaseLayout
  title={`${post.data.title} | MidNiteShadow Online`}
  description={post.data.summary}
  jsonLd={jsonLd}
>
  <Hero
    eyebrow={post.data.category}
    title={post.data.title}
    lede={post.data.summary}
    video={post.data.video}
    videoSrc={post.data.videoSrc}
    videoPoster={post.data.videoPoster}
    image={post.data.hero}
    heroImage={post.data.heroForeground}
    heroImageAlt={post.data.heroForegroundAlt ?? post.data.heroAlt ?? ''}
  />
  <section class="section">
    <div class="container post-layout">
      <article class="prose post-content">
        <Content />
      </article>
      <aside class="post-details-box" aria-label="Post details">
        <p class="post-details-title">Post details</p>
        <div class="post-details-block">
          <p class="post-details-label post-details-label-inline">
            <i class="fa-regular fa-calendar" aria-hidden="true"></i> Posted:
            <span class="post-details-date">
              <time datetime={post.data.date.toISOString()}>
                {formatPostDate(post.data.date)}
              </time>
            </span>
          </p>
        </div>
        <div class="post-details-block">
          <p class="post-details-label">
            <i class="fa-solid fa-folder-open" aria-hidden="true"></i> Category
          </p>
          <a class="tag category-cta" href={`/posts/category/${toSlug(post.data.category)}/`}>
            {post.data.category}
          </a>
        </div>
        {
          post.data.tags.length > 0 && (
            <div class="post-details-block">
              <p class="post-details-label">
                <i class="fa-solid fa-tag" aria-hidden="true" /> Tags
              </p>
              <div class="post-details-tags">
                {post.data.tags.map((tag) => (
                  <a class="tag tag-cta" href={`/posts/tag/${toSlug(tag)}/`}>
                    <i class="fa-solid fa-tag" aria-hidden="true" /> {tag}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </aside>
    </div>
    {
      (prev || next) && (
        <nav class="post-nav" aria-label="Post navigation">
          <div class="container">
            <div class="post-nav-inner">
              <div class="post-nav-slot post-nav-prev">
                {prev && (
                  <a class="post-nav-link" href={`/posts/${postIdToSlug(prev.id)}/`}>
                    <span class="post-nav-dir">
                      <i class="fa-solid fa-angles-left" aria-hidden="true" /> Previous
                    </span>
                    <span class="post-nav-title">{prev.data.title}</span>
                  </a>
                )}
              </div>
              <div class="post-nav-slot post-nav-home">
                <a class="post-nav-link post-nav-home-link" href="/posts/">
                  <i class="fa-solid fa-newspaper" aria-hidden="true" />
                  <span>All posts</span>
                </a>
              </div>
              <div class="post-nav-slot post-nav-next">
                {next && (
                  <a class="post-nav-link" href={`/posts/${postIdToSlug(next.id)}/`}>
                    <span class="post-nav-dir">
                      Next <i class="fa-solid fa-angles-right" aria-hidden="true" />
                    </span>
                    <span class="post-nav-title">{next.data.title}</span>
                  </a>
                )}
              </div>
            </div>
          </div>
        </nav>
      )
    }
  </section>
</BaseLayout>
