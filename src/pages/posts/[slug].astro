---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatPostDate, postIdToSlug, toSlug } from '../../lib/postCategory';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: postIdToSlug(post.id) },
    props: { post },
  }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | MidNiteShadow Online`}
  description={post.data.summary}
>
  <section class="section">
    <div class="container post-layout">
      <article class="prose post-content">
        <h1>{post.data.title}</h1>
        <p class="lede">{post.data.summary}</p>
        {
          post.data.hero && (
            <Image
              class="post-hero-image"
              src={post.data.hero}
              alt={post.data.heroAlt ?? post.data.title}
              loading="eager"
              fetchpriority="high"
            />
          )
        }
        <Content />
      </article>
      <aside class="post-details-box" aria-label="Post details">
        <p class="post-details-title">Post details</p>
        <div class="post-details-block">
          <p class="post-details-label post-details-label-inline">
            <i class="fa-regular fa-calendar" aria-hidden="true"></i> Posted:
            <span class="post-details-date">
              <time datetime={post.data.date.toISOString()}>
                {formatPostDate(post.data.date)}
              </time>
            </span>
          </p>
        </div>
        <div class="post-details-block">
          <p class="post-details-label"><i class="fa-solid fa-folder-open" aria-hidden="true"></i> Category</p>
          <a
            class="tag category-cta"
            href={`/posts/category/${toSlug(post.data.category)}/`}
          >
            {post.data.category}
          </a>
        </div>
        {
          post.data.tags.length > 0 && (
            <div class="post-details-block">
              <p class="post-details-label"><i class="fa-solid fa-tag" aria-hidden="true"></i> Tags</p>
              <div class="post-details-tags">
                {post.data.tags.map((tag) => (
                  <a class="tag tag-cta" href={`/posts/tag/${toSlug(tag)}/`}>
                    <i class="fa-solid fa-tag" aria-hidden="true"></i> {tag}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </aside>
    </div>
  </section>
</BaseLayout>
