---
import BaseLayout from "../layouts/BaseLayout.astro";
import AlertNotice from "../components/AlertNotice.astro";
import Hero from "../components/Hero.astro";
import profileImage from "../assets/images/mns7_profile.webp";
---
<BaseLayout
  title="403 — Access Forbidden | MidNite Shadow Online"
  description="You do not have permission to access this page."
>
  <Hero
    eyebrow="Error 403"
    title="Access Forbidden"
    lede="These shadows are warded against you - you do not have permission to view this page."
    heroImage={profileImage}
    heroImageAlt="MidNite Shadow profile image"
  />
  <section class="section">
    <div class="container prose">
      <AlertNotice variant="error" title="Forbidden">
        <p>
          Access to this resource is restricted. If you believe you should have
          access, please try again later, or return to the home page.
        </p>
      </AlertNotice>
      <p>
        <a href="/" class="button primary">
          <i class="fa-solid fa-house" aria-hidden="true"></i> Return Home
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
