---
import { getCollection, render } from 'astro:content';
import Hero from '../../../components/Hero.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { formatPostDate } from '../../../lib/postCategory';

export async function getStaticPaths() {
  const mods = await getCollection('roll20Mods');
  const entryToSlug = (id: string) =>
    id.replace(/\.(md|mdx)$/i, '').replace(/\/index$/i, '');

  return mods.map((mod) => ({
    params: { slug: entryToSlug(mod.id) },
    props: { mod },
  }));
}

const { mod } = Astro.props;
const { Content } = await render(mod);
---

<BaseLayout
  title={`${mod.data.title} | Roll20 Mods | MidNiteShadow Online`}
  description={mod.data.summary}
>
  <Hero
    eyebrow={mod.data.category}
    title={mod.data.title}
    lede={mod.data.summary}
    video={mod.data.video}
    videoSrc={mod.data.videoSrc}
    videoPoster={mod.data.videoPoster}
    image={mod.data.hero}
    heroImage={mod.data.heroForeground}
    heroImageAlt={mod.data.heroForegroundAlt ?? mod.data.heroAlt ?? ''}
    tags={mod.data.status ? [mod.data.status] : []}
  />
  <section class="section">
    <div class="container post-layout">
      <article class="prose post-content">
        <Content />
      </article>
      <aside class="post-details-box" aria-label="Mod details">
        <p class="post-details-title">Mod details</p>
        {mod.data.status && (
          <div class="post-details-block">
            <p class="post-details-label"><i class="fa-solid fa-circle-dot" aria-hidden="true"></i> Status</p>
            <span class="tag">{mod.data.status}</span>
          </div>
        )}
        {mod.data.version && (
          <div class="post-details-block">
            <p class="post-details-label"><i class="fa-solid fa-code-branch" aria-hidden="true"></i> Version</p>
            <span class="post-details-date">{mod.data.version}</span>
          </div>
        )}
        {mod.data.lastUpdated && (
          <div class="post-details-block">
            <p class="post-details-label post-details-label-inline">
              <i class="fa-regular fa-calendar" aria-hidden="true"></i> Last updated:
              <span class="post-details-date">
                <time datetime={mod.data.lastUpdated.toISOString()}>
                  {formatPostDate(mod.data.lastUpdated)}
                </time>
              </span>
            </p>
          </div>
        )}
        <div class="post-details-block">
          <p class="post-details-label"><i class="fa-solid fa-folder-open" aria-hidden="true"></i> Category</p>
          <span class="tag">{mod.data.category}</span>
        </div>
        {mod.data.maintainer.length > 0 && (
          <div class="post-details-block">
            <p class="post-details-label"><i class="fa-solid fa-user" aria-hidden="true"></i> Maintainer</p>
            <div class="post-details-tags">
              {mod.data.maintainer.map((m) => (
                <a class="tag tag-cta" href={m.url}>{m.name}</a>
              ))}
            </div>
          </div>
        )}
        {mod.data.featuredLinks.length > 0 && (
          <div class="post-details-block">
            <p class="post-details-label"><i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i> Links</p>
            <div class="post-details-tags">
              {mod.data.featuredLinks.map((link) => (
                <a class="tag tag-cta" href={link.url}>{link.label}</a>
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </section>
  <section class="section">
    <div class="container prose">
      <h2>Useful links</h2>
      {mod.data.links.length > 0 ? (
        mod.data.links.map((link) => (
          <p><a href={link.url}>{link.label}</a></p>
        ))
      ) : (
        <p>Useful links will be added here when the packaged release is published.</p>
      )}
    </div>
  </section>
</BaseLayout>
