---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import placeholderImage from '../../../assets/images/placeholder.webp';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getImageLoadingPolicy } from '../../../lib/mediaPriority';

export async function getStaticPaths() {
  const mods = await getCollection('roll20Mods');

  return mods.map((mod) => ({
    params: { slug: mod.id.replace(/\.(md|mdx)$/, '') },
    props: { mod },
  }));
}

const { mod } = Astro.props;
const { Content } = await render(mod);
const heroImagePolicy = getImageLoadingPolicy('hero');
---

<BaseLayout
  title={`${mod.data.title} | Roll20 Mods | MidNiteShadow Online`}
  description={mod.data.summary}
>
  <section class="hero">
    <Image
      class="hero-bg"
      src={mod.data.hero ?? placeholderImage}
      alt=""
      loading={heroImagePolicy.loading}
      fetchpriority={heroImagePolicy.fetchpriority}
      decoding={heroImagePolicy.decoding}
    />
    <div class="container">
      <div class="hero-text">
        <p class="eyebrow">{mod.data.category}</p>
        <h1>{mod.data.title}</h1>
        <p class="lede">{mod.data.summary}</p>
        <div class="meta">
          <span class="tag"
            ><i class="fa-solid fa-tag" aria-hidden="true"></i>
            {mod.data.status}</span>
        </div>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container prose">
      <Content />
      <h2>Download links</h2>
      {
        mod.data.links.length > 0 ? (
          mod.data.links.map((link) => (
            <p>
              <a href={link.url}>{link.label}</a>
            </p>
          ))
        ) : (
          <p>
            Download links will be added here when the packaged release is
            published.
          </p>
        )
      }
    </div>
  </section>
</BaseLayout>
