---
import { getCollection, render } from 'astro:content';
import Hero from '../../../components/Hero.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { formatPostDate, postIdToSlug, toSlug } from '../../../lib/postCategory';

export async function getStaticPaths() {
  const mods = await getCollection('roll20Mods');
  const entryToSlug = (id: string) =>
    id.replace(/\.(md|mdx)$/i, '').replace(/\/index$/i, '');

  return mods.map((mod) => ({
    params: { slug: entryToSlug(mod.id) },
    props: { mod },
  }));
}

const { mod } = Astro.props;
const { Content } = await render(mod);
const normalizedStatus = mod.data.status?.trim().toLowerCase() ?? '';
const isLiveStatus = normalizedStatus === 'active' || normalizedStatus === 'online';
const versionRows =
  mod.data.versions.length > 0
    ? mod.data.versions.map((entry) => ({
        label: entry.label ?? entry.lablel ?? 'Version',
        version: entry.version,
        url: entry.url,
      }))
    : mod.data.version
      ? [{ label: 'Version', version: mod.data.version, url: undefined }]
      : [];
const credits =
  mod.data.credits.length > 0
    ? mod.data.credits
    : mod.data.developers.length > 0
      ? mod.data.developers
    : (mod.data.maintainer ?? []);
const postCategorySlug = mod.data.postCategory ? toSlug(mod.data.postCategory) : undefined;
const relatedPosts = postCategorySlug
  ? (await getCollection('posts'))
      .filter((post) => toSlug(post.data.category) === postCategorySlug)
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
      .slice(0, 5)
  : [];
---

<BaseLayout
  title={`${mod.data.title} | Roll20 Mods | MidNiteShadow Online`}
  description={mod.data.summary}
>
  <Hero
    eyebrow={mod.data.category}
    title={mod.data.title}
    lede={mod.data.summary}
    video={mod.data.video}
    videoSrc={mod.data.videoSrc}
    videoPoster={mod.data.videoPoster}
    image={mod.data.hero}
    heroImage={mod.data.heroForeground}
    heroImageAlt={mod.data.heroForegroundAlt ?? mod.data.heroAlt ?? ''}
    tags={[mod.data.category]}
  />
  <section class="section">
    <div class="container post-layout">
      <article class="prose post-content">
        <Content />
        {relatedPosts.length > 0 && (
          <>
            <hr />
            <h2>Recent posts</h2>
            <ul>
              {relatedPosts.map((post) => (
                <li>
                  <a href={`/posts/${postIdToSlug(post.id)}/`}>{post.data.title}</a>{' '}
                  <span>({formatPostDate(post.data.date)})</span>
                </li>
              ))}
            </ul>
            <p>
              <a href={`/posts/category/${postCategorySlug}/`}>
                View all posts in this category
              </a>
            </p>
          </>
        )}
        <hr />
        <h2>Useful links</h2>
        {mod.data.links.length > 0 ? (
          <ul>
            {mod.data.links.map((link) => (
              <li><a href={link.url}>{link.label}</a></li>
            ))}
          </ul>
        ) : (
          <p>Useful links will be added here when the packaged release is published.</p>
        )}
      </article>
      <aside class="post-details-box" aria-label="Mod details">
        <p class="post-details-title">Mod details</p>
        {mod.data.status && (
          <div class="post-details-block">
            <p class="post-details-label post-details-label-inline">
              <i class="fa-solid fa-circle-dot" aria-hidden="true"></i>
              Status:
              <span class:list={['post-details-date', 'post-details-value', { 'status-text-live': isLiveStatus }]}>
                {mod.data.status}
              </span>
            </p>
          </div>
        )}
        {mod.data.lastUpdated && (
          <div class="post-details-block">
            <p class="post-details-label post-details-label-inline">
              <i class="fa-regular fa-calendar" aria-hidden="true"></i> Last updated:
              <span class="post-details-date post-details-value">
                <time datetime={mod.data.lastUpdated.toISOString()}>
                  {formatPostDate(mod.data.lastUpdated)}
                </time>
              </span>
            </p>
          </div>
        )}
        {versionRows.length > 0 && (
          <div class="post-details-block">
            <p class="post-details-label"><i class="fa-solid fa-code-branch" aria-hidden="true"></i> Versions</p>
            <ul class="post-details-list">
              {versionRows.map((row) => (
                <li>
                  <span class="post-details-list-label post-details-value">{row.label}:</span>{' '}
                  {row.url ? (
                    <a href={row.url}>{row.version}</a>
                  ) : (
                    <span class="post-details-date post-details-value">{row.version}</span>
                  )}
                </li>
              ))}
            </ul>
          </div>
        )}
        {credits.length > 0 && (
          <div class="post-details-block">
            <p class="post-details-label"><i class="fa-solid fa-user" aria-hidden="true"></i> Credits</p>
            <ul class="post-details-list">
              {credits.map((m) => (
                <li><a href={m.url}>{m.name}</a></li>
              ))}
            </ul>
          </div>
        )}
        {mod.data.compatibility.length > 0 && (
          <div class="post-details-block">
            <p class="post-details-label"><i class="fa-solid fa-plug" aria-hidden="true"></i> Compatibility</p>
            <ul class="post-details-list">
              {mod.data.compatibility.map((item) => (
                <li>
                  {item.url ? <a href={item.url}>{item.label}</a> : <span class="post-details-value">{item.label}</span>}
                </li>
              ))}
            </ul>
          </div>
        )}
        {mod.data.requirements.length > 0 && (
          <div class="post-details-block">
            <p class="post-details-label"><i class="fa-solid fa-list-check" aria-hidden="true"></i> Requirements</p>
            <ul class="post-details-list">
              {mod.data.requirements.map((item) => (
                <li>
                  {item.url ? <a href={item.url}>{item.label}</a> : <span class="post-details-value">{item.label}</span>}
                </li>
              ))}
            </ul>
          </div>
        )}
        {mod.data.featuredLinks.length > 0 && (
          <div class="post-details-block">
            <p class="post-details-label"><i class="fa-solid fa-arrow-up-right-from-square" aria-hidden="true"></i> Links</p>
            <ul class="post-details-list">
              {mod.data.featuredLinks.map((link) => (
                <li><a href={link.url}>{link.label}</a></li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>
  </section>
</BaseLayout>
