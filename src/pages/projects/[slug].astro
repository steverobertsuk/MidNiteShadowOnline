---
import { getCollection, render } from "astro:content";
import Hero from "../../components/Hero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CardMedia from "../../components/CardMedia.astro";

function contentIdToSlug(id: string) {
  return id.replace(/\.(md|mdx)$/i, "").replace(/\/index$/i, "");
}

export async function getStaticPaths() {
  const projects = await getCollection("projects");

  return projects.map((project) => ({
    params: {
      slug: project.id.replace(/\.(md|mdx)$/i, "").replace(/\/index$/i, ""),
    },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const slug = contentIdToSlug(project.id);
const heroTags = project.data.status ? [project.data.status] : [];
const heroImageAltText =
  project.data.heroForegroundAlt || project.data.heroAlt || "";
const roll20Mods =
  slug === "roll20-mods"
    ? (await getCollection("roll20Mods")).sort(
        (a, b) => a.data.order - b.data.order,
      )
    : [];
const podcasts =
  slug === "podcasting"
    ? (await getCollection("podcasts")).sort(
        (a, b) => a.data.order - b.data.order,
      )
    : [];
---

<BaseLayout
  title={`${project.data.title} | MidNiteShadow Online`}
  description={project.data.summary}
>
  <Hero
    eyebrow={project.data.category}
    title={project.data.title}
    lede={project.data.summary}
    video={project.data.video}
    videoSrc={project.data.videoSrc}
    videoPoster={project.data.videoPoster}
    image={project.data.hero}
    heroImage={project.data.heroForeground}
    heroImageAlt={heroImageAltText}
    tags={heroTags}
  />
  <section class="section">
    <div class="container prose">
      <Content />

      {
        slug === "roll20-mods" && (
          <>
            <h2>Current mods</h2>
            <div class="grid" style="margin-top: 24px;">
              {roll20Mods.map((mod) => {
                const modSlug = contentIdToSlug(mod.id);

                return (
                  <article class="card large post-card">
                    <CardMedia
                      indexMedia={mod.data.indexMedia}
                      indexMediaAlt={mod.data.indexMediaAlt}
                      indexVideo={mod.data.indexVideo}
                      indexVideoSrc={mod.data.indexVideoSrc}
                      hero={mod.data.hero}
                      video={mod.data.video}
                      videoSrc={mod.data.videoSrc}
                      videoPoster={mod.data.videoPoster}
                    />
                    <h3>
                      <a href={`/projects/roll20-mods/${modSlug}/`}>
                        {mod.data.title}
                      </a>
                    </h3>
                    <p>{mod.data.summary}</p>
                    <a
                      class="button read-more-cta"
                      href={`/projects/roll20-mods/${modSlug}/`}
                    >
                      Read more{" "}
                      <i class="fa-solid fa-angles-right" aria-hidden="true" />
                    </a>
                  </article>
                );
              })}
            </div>
          </>
        )
      }

      {
        slug === "podcasting" && (
          <>
            <h2>Main Podcasts</h2>
            <div class="grid" style="margin-top: 24px;">
              {podcasts.map((podcast) => {
                const podcastSlug = contentIdToSlug(podcast.id);

                return (
                  <article class="card large post-card">
                    <CardMedia
                      indexMedia={podcast.data.indexMedia}
                      indexMediaAlt={podcast.data.indexMediaAlt}
                      indexVideo={podcast.data.indexVideo}
                      indexVideoSrc={podcast.data.indexVideoSrc}
                      hero={podcast.data.hero}
                      video={podcast.data.video}
                      videoSrc={podcast.data.videoSrc}
                      videoPoster={podcast.data.videoPoster}
                    />
                    <h3>
                      <a href={`/projects/podcasting/${podcastSlug}/`}>
                        {podcast.data.title}
                      </a>
                    </h3>
                    <p>{podcast.data.summary}</p>
                    <a
                      class="button read-more-cta"
                      href={`/projects/podcasting/${podcastSlug}/`}
                    >
                      Read more{" "}
                      <i class="fa-solid fa-angles-right" aria-hidden="true" />
                    </a>
                    <div class="card-tags">
                      <span class="tag">
                        <i class="fa-solid fa-tag" aria-hidden="true" />{" "}
                        {podcast.data.category}
                      </span>
                      {podcast.data.status && (
                        <span class="tag">
                          <i class="fa-solid fa-tag" aria-hidden="true" />{" "}
                          {podcast.data.status}
                        </span>
                      )}
                    </div>
                  </article>
                );
              })}
            </div>

            <h2>Supporting Projects</h2>
            <div class="grid" style="margin-top: 24px;">
              <article class="card large">
                <h3>
                  <a href="https://holosuitemedia.com/archived-podcasts/starbaseone/">
                    Starbase One
                  </a>
                </h3>
                <p>
                  I was a guest and co-host for the Trek News and Views Podcast,
                  a Star Trek Online podcast that covered news, reviews, and
                  discussions about all things Star Trek Online.
                </p>
                <p>
                  In 2020, I became one of the main podcast hosts and audio
                  editor and as part of the show's relaunch on its new network
                  <a href="https://holosuitemedia.com">Holosuite Media</a> where
                  the show was renamed and rebranded as{" "}
                  <a href="https://holosuitemedia.com/archived-podcasts/starbaseone/">
                    Starbase One
                  </a>
                  .
                </p>
                <p>
                  Assisting with the production and hosting of multiple other
                  shows that started on Holosuite Media during COVID-19, plus
                  the death of co-host Colin, the show was discontinued.
                </p>
                <div class="card-tags">
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    2016 - 2020
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Podcaster
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Web Hosting
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Podcast Network
                  </span>
                </div>
              </article>
              <article class="card large">
                <h3>
                  <a href="https://www.priorityonepodcast.com/">
                    Priority One Podcast
                  </a>
                </h3>
                <p>
                  Support Staff and QA Consultant for the Priority One Podcast,
                  a Star Trek-themed podcast that covered news, reviews, and
                  discussions about all things Star Trek and Star Trek Online.
                </p>
                <p>
                  Contributions included providing audio editing support for the
                  Priority One Productions team, and quality assurance checks to
                  ensure high production standards and listener satisfaction.
                </p>
                <p>
                  I also moderated the Priority One Fleet forums, fostering
                  community engagement and support for Star Trek Online MMO
                  fleet members.
                </p>
                <div class="card-tags">
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    2017 - 2020
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Audio Editing
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Quality Assurance
                  </span>
                </div>
              </article>
              <article class="card large">
                <h3>
                  <a href="https://ussstarfinder.com/">Star Trek Starfinder</a>
                </h3>
                <p>
                  Voice artist for the fan-production of Star Trek Starfinder,
                  an audio drama where I portrayed the character of Chef aboard
                  the U.S.S. Starfinder.
                </p>
                <p>
                  Additionally, I hosted and maintained the project's website
                  and I served as a community manager for Star Trek Starfinder,
                  engaging with fans and providing support to enhance the gaming
                  experience for players.
                </p>
                <div class="card-tags">
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    2014 - 2020
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    2025 - present
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Voice Acting
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Community Management
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Web Hosting
                  </span>
                </div>
              </article>
              <article class="card large">
                <h3>
                  <a href="https://starbaseugc.com">StarbaseUGC Podcast</a>
                </h3>
                <p>
                  I was a guest host on the StarbaseUGC Podcast, a Star Trek
                  Online podcast that covered all things Foundry (the
                  user-generated content system) including Foundry's role in the
                  Star Trek Online MMO.
                </p>
                <p>
                  More recently, I have continued to contribute to the podcast
                  by hosting the StarbaseUGC Podcast's website to allow
                  listeners to access archived episodes and additional content
                  such as Star Trek: Reliant, a podcast based on the Star Trek
                  Adventures tabletop RPG.
                </p>
                <div class="card-tags">
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    2018 - 2019
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    2022 - present
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Podcaster
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Web Hosting
                  </span>
                </div>
              </article>
              <article class="card large">
                <h3>G&amp;T Show Podcasts</h3>
                <p>
                  I was a co-host and audio engineer for the G&T Show's Book of
                  the Celestial Temple Book Club, and a regular guest co-host of
                  the main G&T Show. For both shows, I often assisted with that
                  show's audio editing, broadcasting, publishing, and event
                  management.
                </p>
                <div class="card-tags">
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    2017 - 2020
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Audio Editing
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Podcaster
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Broadcaster
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Content Contributor
                  </span>
                </div>
              </article>
              <article class="card large">
                <h3>Perfect World Entertainment</h3>
                <p>
                  I was a Volunteer Forum Moderator for the Star Trek Online
                  forums. I actively moderated and responded to user inquiries,
                  online forums for the Star Trek Online MMO, ensuring a
                  positive user experience. I removed spam and inappropriate
                  messages to maintain community standards. I collaborated with
                  other moderators to handle user issues and enforce forum
                  guidelines, fostering a welcoming environment.
                </p>
                <div class="card-tags">
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    2018 - 2019
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Forum Moderation
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    Community Management
                  </span>
                  <span class="tag">
                    <i class="fa-solid fa-tag" aria-hidden="true" />
                    User Support
                  </span>
                </div>
              </article>
            </div>
          </>
        )
      }

      {project.data.links.length > 0 && <h2>Links</h2>}
      {
        project.data.links.map((link) => (
          <p>
            <a href={link.url}>{link.label}</a>
          </p>
        ))
      }
    </div>
  </section>
</BaseLayout>
