---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import placeholderImage from '../../assets/images/placeholder.webp';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.(md|mdx)$/, '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const slug = project.id.replace(/\.(md|mdx)$/, '');
const roll20Mods =
  slug === 'roll20-mods'
    ? (await getCollection('roll20Mods')).sort(
        (a, b) => a.data.order - b.data.order,
      )
    : [];
const podcasts =
  slug === 'podcasting'
    ? (await getCollection('podcasts')).sort(
        (a, b) => a.data.order - b.data.order,
      )
    : [];
---

<BaseLayout
  title={`${project.data.title} | MidNiteShadow Online`}
  description={project.data.summary}
>
  <section class="hero">
    <Image
      class="hero-bg"
      src={project.data.hero ?? placeholderImage}
      alt=""
      loading="eager"
      fetchpriority="high"
    />
    <div class="container">
      <p class="eyebrow">{project.data.category}</p>
      <h1>{project.data.title}</h1>
      <p class="lede">{project.data.summary}</p>
      <div class="meta"><span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> {project.data.status}</span></div>
    </div>
  </section>
  <section class="section">
    <div class="container prose">
      <Content />

      {
        slug === 'roll20-mods' && (
          <>
            <h2>Current mods</h2>
            <div class="grid" style="margin-top: 24px;">
              {roll20Mods.map((mod) => {
                const modSlug = mod.id.replace(/\.(md|mdx)$/, '');

                return (
                  <article class="card large post-card">
                    {mod.data.hero && (
                      <Image
                        class="project-image"
                        src={mod.data.hero}
                        alt=""
                        loading="lazy"
                        fetchpriority="low"
                      />
                    )}
                    <h3>
                      <a href={`/projects/roll20-mods/${modSlug}/`}>
                        {mod.data.title}
                      </a>
                    </h3>
                    <p>{mod.data.summary}</p>
                    <a
                      class="button read-more-cta"
                      href={`/projects/roll20-mods/${modSlug}/`}
                    >Read more <i class="fa-solid fa-angles-right" aria-hidden="true"></i></a>
                    <div class="card-tags">
                      <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> {mod.data.category}</span>
                      <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> {mod.data.status}</span>
                    </div>
                  </article>
                );
              })}
            </div>
          </>
        )
      }

      {
        slug === 'podcasting' && (
          <>
            <h2>Current podcasts</h2>
            <div class="grid" style="margin-top: 24px;">
              {podcasts.map((podcast) => {
                const podcastSlug = podcast.id.replace(/\.(md|mdx)$/, '');

                return (
                  <article class="card large post-card">
                    {podcast.data.hero && (
                      <Image
                        class="project-image"
                        src={podcast.data.hero}
                        alt=""
                        loading="lazy"
                        fetchpriority="low"
                      />
                    )}
                    <h3>
                      <a href={`/projects/podcasting/${podcastSlug}/`}>
                        {podcast.data.title}
                      </a>
                    </h3>
                    <p>{podcast.data.summary}</p>
                    <a
                      class="button read-more-cta"
                      href={`/projects/podcasting/${podcastSlug}/`}
                    >Read more <i class="fa-solid fa-angles-right" aria-hidden="true"></i></a>
                    <div class="card-tags">
                      <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> {podcast.data.category}</span>
                      <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> {podcast.data.status}</span>
                    </div>
                  </article>
                );
              })}
            </div>

            <h2>Audio editing and other appearances</h2>
            <div class="grid" style="margin-top: 24px;">
              <article class="card large">
                <h3>Audio editing workflow</h3>
                <p>
                  Editing notes include cleanup strategy, EQ and leveling
                  preferences, mastering targets, and file handoff standards
                  used for consistent releases.
                </p>
              </article>
              <article class="card large">
                <h3>Other appearances</h3>
                <p>
                  Guest spots, crossover episodes, and live panel appearances
                  are tracked here with links, release dates, and quick context
                  for each appearance.
                </p>
              </article>
            </div>
          </>
        )
      }

      {project.data.links.length > 0 && <h2>Links</h2>}
      {
        project.data.links.map((link) => (
          <p>
            <a href={link.url}>{link.label}</a>
          </p>
        ))
      }
    </div>
  </section>
</BaseLayout>
