---
import { getCollection, render } from 'astro:content';
import Hero from '../../components/Hero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CardMedia from '../../components/CardMedia.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.(md|mdx)$/, '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const slug = project.id.replace(/\.(md|mdx)$/, '');
const roll20Mods =
  slug === 'roll20-mods'
    ? (await getCollection('roll20Mods')).sort(
        (a, b) => a.data.order - b.data.order,
      )
    : [];
const podcasts =
  slug === 'podcasting'
    ? (await getCollection('podcasts')).sort(
        (a, b) => a.data.order - b.data.order,
      )
    : [];
---

<BaseLayout
  title={`${project.data.title} | MidNiteShadow Online`}
  description={project.data.summary}
>
  <Hero
    eyebrow={project.data.category}
    title={project.data.title}
    lede={project.data.summary}
    video={project.data.video}
    videoSrc={project.data.videoSrc}
    videoPoster={project.data.videoPoster}
    image={project.data.hero}
    heroImage={project.data.heroForeground}
    heroImageAlt={project.data.heroForegroundAlt ?? project.data.heroAlt ?? ''}
    tags={[project.data.status]}
  />
  <section class="section">
    <div class="container prose">
      <Content />

      {
        slug === 'roll20-mods' && (
          <>
            <h2>Current mods</h2>
            <div class="grid" style="margin-top: 24px;">
              {roll20Mods.map((mod) => {
                const modSlug = mod.id.replace(/\.(md|mdx)$/, '');

                return (
                  <article class="card large post-card">
                    <CardMedia
                      indexMedia={mod.data.indexMedia}
                      indexMediaAlt={mod.data.indexMediaAlt}
                      indexVideo={mod.data.indexVideo}
                      indexVideoSrc={mod.data.indexVideoSrc}
                      hero={mod.data.hero}
                      video={mod.data.video}
                      videoSrc={mod.data.videoSrc}
                      videoPoster={mod.data.videoPoster}
                    />
                    <h3>
                      <a href={`/projects/roll20-mods/${modSlug}/`}>
                        {mod.data.title}
                      </a>
                    </h3>
                    <p>{mod.data.summary}</p>
                    <a
                      class="button read-more-cta"
                      href={`/projects/roll20-mods/${modSlug}/`}
                    >
                      Read more{' '}
                      <i class="fa-solid fa-angles-right" aria-hidden="true" />
                    </a>
                  </article>
                );
              })}
            </div>
          </>
        )
      }

      {
        slug === 'podcasting' && (
          <>
            <h2>Current podcasts</h2>
            <div class="grid" style="margin-top: 24px;">
              {podcasts.map((podcast) => {
                const podcastSlug = podcast.id.replace(/\.(md|mdx)$/, '');

                return (
                  <article class="card large post-card">
                    <CardMedia
                      indexMedia={podcast.data.indexMedia}
                      indexMediaAlt={podcast.data.indexMediaAlt}
                      indexVideo={podcast.data.indexVideo}
                      indexVideoSrc={podcast.data.indexVideoSrc}
                      hero={podcast.data.hero}
                      video={podcast.data.video}
                      videoSrc={podcast.data.videoSrc}
                      videoPoster={podcast.data.videoPoster}
                    />
                    <h3>
                      <a href={`/projects/podcasting/${podcastSlug}/`}>
                        {podcast.data.title}
                      </a>
                    </h3>
                    <p>{podcast.data.summary}</p>
                    <a
                      class="button read-more-cta"
                      href={`/projects/podcasting/${podcastSlug}/`}
                    >
                      Read more{' '}
                      <i class="fa-solid fa-angles-right" aria-hidden="true" />
                    </a>
                    <div class="card-tags">
                      <span class="tag">
                        <i class="fa-solid fa-tag" aria-hidden="true" />{' '}
                        {podcast.data.category}
                      </span>
                      <span class="tag">
                        <i class="fa-solid fa-tag" aria-hidden="true" />{' '}
                        {podcast.data.status}
                      </span>
                    </div>
                  </article>
                );
              })}
            </div>

            <h2>Audio editing and other appearances</h2>
            <div class="grid" style="margin-top: 24px;">
              <article class="card large">
                <h3>Audio editing workflow</h3>
                <p>
                  Editing notes include cleanup strategy, EQ and leveling
                  preferences, mastering targets, and file handoff standards
                  used for consistent releases.
                </p>
              </article>
              <article class="card large">
                <h3>Other appearances</h3>
                <p>
                  Guest spots, crossover episodes, and live panel appearances
                  are tracked here with links, release dates, and quick context
                  for each appearance.
                </p>
              </article>
            </div>
          </>
        )
      }

      {project.data.links.length > 0 && <h2>Links</h2>}
      {
        project.data.links.map((link) => (
          <p>
            <a href={link.url}>{link.label}</a>
          </p>
        ))
      }
    </div>
  </section>
</BaseLayout>
