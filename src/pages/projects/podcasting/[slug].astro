---
import { getCollection, render } from 'astro:content';
import Hero from '../../../components/Hero.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const podcasts = await getCollection('podcasts');

  return podcasts.map((podcast) => ({
    params: { slug: podcast.id.replace(/\.(md|mdx)$/, '') },
    props: { podcast },
  }));
}

const { podcast } = Astro.props;
const { Content } = await render(podcast);
---

<BaseLayout
  title={`${podcast.data.title} | Podcasting | MidNiteShadow Online`}
  description={podcast.data.summary}
>
  <Hero
    eyebrow={podcast.data.category}
    title={podcast.data.title}
    lede={podcast.data.summary}
    image={podcast.data.hero}
    tags={[podcast.data.status]}
  />
  <section class="section">
    <div class="container prose">
      <Content />
      <h2>Listen and follow</h2>
      {
        podcast.data.links.length > 0 ? (
          podcast.data.links.map((link) => (
            <p>
              <a href={link.url}>{link.label}</a>
            </p>
          ))
        ) : (
          <p>Show links will be added here as they are published.</p>
        )
      }
    </div>
  </section>
</BaseLayout>
