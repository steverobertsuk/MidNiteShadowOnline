---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import placeholderImage from "../../assets/images/placeholder.webp";
---

<BaseLayout
  title="Ulrick | D&D | MidNiteShadow Online"
  description="Campaign notes and character overview for Ulrick."
>
  <section class="hero">
    <Image class="hero-bg" src={placeholderImage} alt="" loading="eager" fetchpriority="high" />
    <div class="container">
      <p class="eyebrow">D&D Character</p>
      <h1>Ulrick</h1>
      <p class="lede">
        A character page for major beats, session history, and longer-term arc
        planning.
      </p>
      <div class="meta">
        <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> Character</span><span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> D&D</span>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container prose">
      <h2>Overview</h2>
      <p>
        Ulrick's page is set up for character background, campaign milestones,
        and the evolving details that help keep the arc coherent over a longer
        run.
      </p>
      <h2>Campaign notes</h2>
      <p>
        Use this space to record defining encounters, personal stakes, and any
        unresolved threads that should return in later sessions.
      </p>
    </div>
  </section>
</BaseLayout>
