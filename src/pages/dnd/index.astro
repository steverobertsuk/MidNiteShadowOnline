---
import CardMedia from '../../components/CardMedia.astro';
import Hero from '../../components/Hero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import dndImage from "../../assets/images/dnd-characters/dnd-cover.jpg";
import modsImage from "../../assets/images/mods/roll20-mods-cover.jpg";

const dndEntries = (await getCollection('dnd')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout
  title="D&D | MidNiteShadow Online"
  description="A home for Midnight Realm, campaign notes, lore, mechanics, tokens, one-shots and reusable tabletop material."
>
  <Hero
    eyebrow="D&D / Tabletop"
    title="Worldbuilding, characters and session design."
    lede="A home for Midnight Realm, campaign notes, lore, mechanics, tokens, one-shots and reusable tabletop material."
    image={dndImage}
  />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Characters & tools</p>
      <h1>Campaign leads and supporting tools</h1>
      <p class="lede">
        Explore the current D&D character pages, then jump to the Roll20 Mods
        project for tabletop automation and supporting utilities.
      </p>
      <div class="grid" style="margin-top: 40px;">
        {
          dndEntries.map((entry) => {
            const slug = entry.id.replace(/\.(md|mdx)$/, '');

            return (
              <article class="card large post-card">
                <CardMedia
                  indexMedia={entry.data.indexMedia}
                  indexMediaAlt={entry.data.indexMediaAlt}
                  hero={entry.data.hero}
                />
                <h3><a href={`/dnd/${slug}/`}>{entry.data.title}</a></h3>
                <p>{entry.data.summary}</p>
                <a class="button read-more-cta" href={`/dnd/${slug}/`}>
                  Read more{' '}
                  <i class="fa-solid fa-angles-right" aria-hidden="true" />
                </a>
                {entry.data.tags.length > 0 && (
                  <div class="card-tags">
                    {entry.data.tags.map((tag) => (
                      <span class="tag">
                        <i class="fa-solid fa-tag" aria-hidden="true" /> {tag}
                      </span>
                    ))}
                  </div>
                )}
              </article>
            );
          })
        }
        <article class="card large post-card">
          <CardMedia
            indexMedia={modsImage}
            indexMediaAlt="Roll20 Mods cover image"
          />
          <h3><a href="/projects/roll20-mods/">Roll20 Mods</a></h3>
          <p>
            Open the Roll20 Mods project page for token tools, condition
            automation, health colour scripts, and related tabletop workflows.
          </p>
          <a class="button read-more-cta" href="/projects/roll20-mods/"
            >Read more <i class="fa-solid fa-angles-right" aria-hidden="true"
            ></i></a
          >
          <div class="card-tags">
            <span class="tag"
              ><i class="fa-solid fa-tag" aria-hidden="true"></i> Project</span
            >
            <span class="tag"
              ><i class="fa-solid fa-tag" aria-hidden="true"></i> Tabletop tooling</span
            >
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
