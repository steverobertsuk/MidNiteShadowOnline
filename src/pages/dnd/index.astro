---
import { Image } from 'astro:assets';
import placeholderImage from '../../assets/images/placeholder.webp';
import Hero from '../../components/Hero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getImageLoadingPolicy } from '../../lib/mediaPriority';

const cardImagePolicy = getImageLoadingPolicy('card');
---

<BaseLayout title="D&D | MidNiteShadow Online">
  <Hero
    eyebrow="D&D / Tabletop"
    title="Worldbuilding, characters and session design."
    lede="A home for Midnight Realm, campaign notes, lore, mechanics, tokens, one-shots and reusable tabletop material."
  />
  <section class="section">
    <div class="container">
      <p class="eyebrow">Characters & tools</p>
      <h1>Campaign leads and supporting tools</h1>
      <p class="lede">
        Explore the current D&D character pages, then jump to the Roll20 Mods
        project for tabletop automation and supporting utilities.
      </p>
      <div class="grid" style="margin-top: 40px;">
        <article class="card large post-card">
          <Image
            class="project-image"
            src={placeholderImage}
            alt=""
            loading={cardImagePolicy.loading}
            fetchpriority={cardImagePolicy.fetchpriority}
            decoding={cardImagePolicy.decoding}
          />
          <h3><a href="/dnd/dorn/">Dorn</a></h3>
          <p>
            A dedicated page for Dorn's place in the campaign, role at the
            table, and future story hooks.
          </p>
          <a class="button read-more-cta" href="/dnd/dorn/"
            >Read more <i class="fa-solid fa-angles-right" aria-hidden="true"
            ></i></a
          >
          <div class="card-tags">
            <span class="tag"
              ><i class="fa-solid fa-tag" aria-hidden="true"></i> Character</span
            >
            <span class="tag"
              ><i class="fa-solid fa-tag" aria-hidden="true"></i> D&D</span
            >
          </div>
        </article>
        <article class="card large post-card">
          <Image
            class="project-image"
            src={placeholderImage}
            alt=""
            loading={cardImagePolicy.loading}
            fetchpriority={cardImagePolicy.fetchpriority}
            decoding={cardImagePolicy.decoding}
          />
          <h3><a href="/dnd/nox/">Nox</a></h3>
          <p>
            A dedicated page for Nox's backstory, party role, and key
            worldbuilding connections.
          </p>
          <a class="button read-more-cta" href="/dnd/nox/"
            >Read more <i class="fa-solid fa-angles-right" aria-hidden="true"
            ></i></a
          >
          <div class="card-tags">
            <span class="tag"
              ><i class="fa-solid fa-tag" aria-hidden="true"></i> Character</span
            >
            <span class="tag"
              ><i class="fa-solid fa-tag" aria-hidden="true"></i> D&D</span
            >
          </div>
        </article>
        <article class="card large post-card">
          <Image
            class="project-image"
            src={placeholderImage}
            alt=""
            loading={cardImagePolicy.loading}
            fetchpriority={cardImagePolicy.fetchpriority}
            decoding={cardImagePolicy.decoding}
          />
          <h3><a href="/dnd/ulrick/">Ulrick</a></h3>
          <p>
            A dedicated page for Ulrick's campaign material, major beats, and
            developing character notes.
          </p>
          <a class="button read-more-cta" href="/dnd/ulrick/"
            >Read more <i class="fa-solid fa-angles-right" aria-hidden="true"
            ></i></a
          >
          <div class="card-tags">
            <span class="tag"
              ><i class="fa-solid fa-tag" aria-hidden="true"></i> Character</span
            >
            <span class="tag"
              ><i class="fa-solid fa-tag" aria-hidden="true"></i> D&D</span
            >
          </div>
        </article>
        <article class="card large post-card">
          <Image
            class="project-image"
            src={placeholderImage}
            alt=""
            loading={cardImagePolicy.loading}
            fetchpriority={cardImagePolicy.fetchpriority}
            decoding={cardImagePolicy.decoding}
          />
          <h3><a href="/projects/roll20-mods/">Roll20 Mods</a></h3>
          <p>
            Open the Roll20 Mods project page for token tools, condition
            automation, health colour scripts, and related tabletop workflows.
          </p>
          <a class="button read-more-cta" href="/projects/roll20-mods/"
            >Read more <i class="fa-solid fa-angles-right" aria-hidden="true"
            ></i></a
          >
          <div class="card-tags">
            <span class="tag"
              ><i class="fa-solid fa-tag" aria-hidden="true"></i> Project</span
            >
            <span class="tag"
              ><i class="fa-solid fa-tag" aria-hidden="true"></i> Tabletop tooling</span
            >
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
