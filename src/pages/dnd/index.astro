---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import placeholderImage from '../../assets/images/placeholder.webp';
---

<BaseLayout title="D&D | MidNiteShadow Online">
  <section class="hero">
    <Image class="hero-bg" src={placeholderImage} alt="" loading="eager" fetchpriority="high" /><div
      class="container"
    >
      <p class="eyebrow">D&D / Tabletop</p><h1>
        Worldbuilding, characters and session design.
      </h1><p class="lede">
        A home for Midnight Realm, campaign notes, lore, mechanics, tokens,
        one-shots and reusable tabletop material.
      </p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <p class="eyebrow">Characters & tools</p>
      <h1>Campaign leads and supporting tools</h1>
      <p class="lede">
        Explore the current D&D character pages, then jump to the Roll20 Mods
        project for tabletop automation and supporting utilities.
      </p>
      <div class="grid" style="margin-top: 40px;">
        <article class="card large post-card">
          <Image
            class="project-image"
            src={placeholderImage}
            alt=""
            loading="lazy"
            fetchpriority="low"
          />
          <h3><a href="/dnd/dorn/">Dorn</a></h3>
          <p>
            A dedicated page for Dorn's place in the campaign, role at the
            table, and future story hooks.
          </p>
          <a class="button read-more-cta" href="/dnd/dorn/">Read more</a>
          <div class="card-tags">
            <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> Character</span>
            <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> D&D</span>
          </div>
        </article>
        <article class="card large post-card">
          <Image
            class="project-image"
            src={placeholderImage}
            alt=""
            loading="lazy"
            fetchpriority="low"
          />
          <h3><a href="/dnd/nox/">Nox</a></h3>
          <p>
            A dedicated page for Nox's backstory, party role, and key
            worldbuilding connections.
          </p>
          <a class="button read-more-cta" href="/dnd/nox/">Read more</a>
          <div class="card-tags">
            <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> Character</span>
            <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> D&D</span>
          </div>
        </article>
        <article class="card large post-card">
          <Image
            class="project-image"
            src={placeholderImage}
            alt=""
            loading="lazy"
            fetchpriority="low"
          />
          <h3><a href="/dnd/ulrick/">Ulrick</a></h3>
          <p>
            A dedicated page for Ulrick's campaign material, major beats, and
            developing character notes.
          </p>
          <a class="button read-more-cta" href="/dnd/ulrick/">Read more</a>
          <div class="card-tags">
            <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> Character</span>
            <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> D&D</span>
          </div>
        </article>
        <article class="card large post-card">
          <Image
            class="project-image"
            src={placeholderImage}
            alt=""
            loading="lazy"
            fetchpriority="low"
          />
          <h3><a href="/projects/roll20-mods/">Roll20 Mods</a></h3>
          <p>
            Open the Roll20 Mods project page for token tools, condition
            automation, health colour scripts, and related tabletop workflows.
          </p>
          <a class="button read-more-cta" href="/projects/roll20-mods/"
            >Read more</a
          >
          <div class="card-tags">
            <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> Project</span>
            <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> Tabletop tooling</span>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
