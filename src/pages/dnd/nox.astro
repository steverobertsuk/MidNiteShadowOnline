---
import Hero from '../../components/Hero.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nox | D&D | MidNiteShadow Online"
  description="Campaign notes and character overview for Nox."
>
  <Hero
    eyebrow="D&D Character"
    title="Nox"
    lede="A character page for backstory, world connections, and future campaign developments."
    tags={['Character', 'D&D']}
  />
  <section class="section">
    <div class="container prose">
      <h2>Overview</h2>
      <p>
        Nox's page provides a place to gather core identity notes, roleplaying
        beats, and the relationships that tie the character into the wider
        setting.
      </p>
      <h2>Campaign notes</h2>
      <p>
        Use this page for faction ties, secrets, motivations, and evolving story
        consequences that matter to Nox over time.
      </p>
    </div>
  </section>
</BaseLayout>
