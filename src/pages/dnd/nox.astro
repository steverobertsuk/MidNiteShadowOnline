---
import { Image } from 'astro:assets';
import placeholderImage from '../../assets/images/placeholder.webp';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getImageLoadingPolicy } from '../../lib/mediaPriority';

const heroImagePolicy = getImageLoadingPolicy('hero');
---

<BaseLayout
  title="Nox | D&D | MidNiteShadow Online"
  description="Campaign notes and character overview for Nox."
>
  <section class="hero">
    <Image
      class="hero-bg"
      src={placeholderImage}
      alt=""
      loading={heroImagePolicy.loading}
      fetchpriority={heroImagePolicy.fetchpriority}
      decoding={heroImagePolicy.decoding}
    />
    <div class="container">
      <div class="hero-text">
        <p class="eyebrow">D&D Character</p>
        <h1>Nox</h1>
        <p class="lede">
          A character page for backstory, world connections, and future campaign
          developments.
        </p>
        <div class="meta">
          <span class="tag"
            ><i class="fa-solid fa-tag" aria-hidden="true"></i> Character</span
          ><span class="tag"
            ><i class="fa-solid fa-tag" aria-hidden="true"></i> D&D</span
          >
        </div>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container prose">
      <h2>Overview</h2>
      <p>
        Nox's page provides a place to gather core identity notes, roleplaying
        beats, and the relationships that tie the character into the wider
        setting.
      </p>
      <h2>Campaign notes</h2>
      <p>
        Use this page for faction ties, secrets, motivations, and evolving story
        consequences that matter to Nox over time.
      </p>
    </div>
  </section>
</BaseLayout>
