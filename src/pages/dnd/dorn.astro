---
import { Image } from 'astro:assets';
import placeholderImage from '../../assets/images/placeholder.webp';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getImageLoadingPolicy } from '../../lib/mediaPriority';

const heroImagePolicy = getImageLoadingPolicy('hero');
---

<BaseLayout
  title="Dorn | D&D | MidNiteShadow Online"
  description="Campaign notes and character overview for Dorn."
>
  <section class="hero">
    <Image
      class="hero-bg"
      src={placeholderImage}
      alt=""
      loading={heroImagePolicy.loading}
      fetchpriority={heroImagePolicy.fetchpriority}
      decoding={heroImagePolicy.decoding}
    />
    <div class="container">
      <div class="hero-text">
        <p class="eyebrow">D&D Character</p>
        <h1>Dorn</h1>
        <p class="lede">
          A character page for campaign role, story hooks, and future
          development notes.
        </p>
        <div class="meta">
          <span class="tag"
            ><i class="fa-solid fa-tag" aria-hidden="true"></i> Character</span
          ><span class="tag"
            ><i class="fa-solid fa-tag" aria-hidden="true"></i> D&D</span
          >
        </div>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container prose">
      <h2>Overview</h2>
      <p>
        Dorn's page is ready to collect backstory notes, campaign history, party
        dynamics, and any session-by-session updates that should stay attached
        to the character.
      </p>
      <h2>Campaign notes</h2>
      <p>
        Use this page to track goals, allies, unresolved threads, and major
        moments that shape Dorn's arc across the campaign.
      </p>
    </div>
  </section>
</BaseLayout>
