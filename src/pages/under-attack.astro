---
import BaseLayout from '../layouts/BaseLayout.astro';
import AlertNotice from '../components/AlertNotice.astro';
import Hero from '../components/Hero.astro';
import profileImage from '../assets/images/mns7_profile.webp';
---

<BaseLayout
  title="Checking Your Browser | MidNite Shadow Online"
  description="Your browser is being checked before you continue to the site."
>
  <Hero
    eyebrow="Security Check"
    title="Checking Your Browser"
    lede="The gates are sealed for a moment while your browser is checked - you will continue automatically."
    heroImage={profileImage}
    heroImageAlt="MidNite Shadow profile image"
  />
  <section class="section">
    <div class="container prose">
      <AlertNotice variant="warning" title="Automatic Check In Progress">
        <p>
          This site is under heightened protection. The check completes on its own within a few
          seconds - no action is needed.
        </p>
      </AlertNotice>
      <!-- Cloudflare replaces this token with the browser check widget when
           this page is served from the zone's Non-Interactive Challenge
           custom page slot. -->
      <div class="cf-error-details">::IM_UNDER_ATTACK_BOX::</div>
    </div>
  </section>
</BaseLayout>
