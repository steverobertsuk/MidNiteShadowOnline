---
import { Image } from 'astro:assets';
import '../styles/global.css';
import brandMarkIcon from '../assets/icons/mns7-icon.png';
const {
  title = 'MidNiteShadow Online',
  description = 'Gaming, tabletop worlds, Roll20 mods, STO Info and podcasting projects.',
} = Astro.props;

const siteName = 'MidNiteShadow Online';
const author = 'Steve Roberts';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://midniteshadow.online').href;
const imageAlt = `${siteName} — ${description}`;
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="theme-color" content="#0a0a12" />
    <link rel="canonical" href={canonical} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/assets/images/placeholder.webp" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content="/assets/icons/android-chrome-512x512.png"
    />
    <meta name="twitter:image:alt" content={imageAlt} />
    <meta
      name="msapplication-config"
      content="/assets/icons/browserconfig.xml"
    />
    <link rel="icon" href="/assets/icons/favicon.ico" sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/assets/icons/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/assets/icons/favicon-16x16.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/assets/icons/apple-touch-icon.png"
    />
    <link
      rel="mask-icon"
      href="/assets/icons/safari-pinned-tab.svg"
      color="#6a0dad"
    />
    <link rel="manifest" href="/assets/icons/site.webmanifest" />
    <title>{title}</title>
  </head>
  <body>
    <video class="page-bg-video" autoplay muted loop playsinline aria-hidden="true">
      <source src="/assets/video/hero-purple-smoke.webm" type="video/webm" />
    </video>
    <div class="smoke-css" aria-hidden="true"></div>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">
            <Image
              class="brand-mark-icon"
              src={brandMarkIcon}
              loading="eager"
              alt=""
            />
          </span>
          <span>MidNite Shadow Online</span>
        </a>
        <nav class="nav-links" aria-label="Primary navigation">
          <a href="/gaming/"><i class="fa-solid fa-gamepad" aria-hidden="true"></i> Gaming</a>
          <a href="/projects/sto-info/"><i class="fa-solid fa-star" aria-hidden="true"></i> STO Info</a>
          <a href="/dnd/"><i class="fa-solid fa-dice-d20" aria-hidden="true"></i> D&D</a>
          <a href="/projects/roll20-mods/"><i class="fa-solid fa-gears" aria-hidden="true"></i> Roll20 Mods</a>
          <a href="/projects/podcasting/"><i class="fa-solid fa-microphone-lines" aria-hidden="true"></i> Podcasting</a>
          <a href="/posts/"><i class="fa-solid fa-newspaper" aria-hidden="true"></i> Posts</a>
          <a class="button" href="/projects/"><i class="fa-solid fa-diagram-project" aria-hidden="true"></i> Projects</a>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="footer">
      <div class="container">
        <strong>MidNite Shadow Online</strong>
        <p>
          Gaming projects, tabletop worlds, Roll20 tools, podcast production and
          technical creativity.
        </p>
      </div>
    </footer>
    <script is:inline src="https://kit.fontawesome.com/997e87a249.js" crossorigin="anonymous"></script>
  </body>
</html>
