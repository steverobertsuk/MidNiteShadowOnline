---
import { Image } from 'astro:assets';
import brandMarkIcon from '../assets/icons/mns7-icon.png';
import mns7RoundIcon from '../assets/icons/mns7_round_icon.webp';
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';
import pkg from '../../package.json';
import {
  getImageLoadingPolicy,
  getVideoLoadingPolicy,
  type ResponsivePreload,
} from '../lib/mediaPriority';
const {
  title = 'MidNite Shadow Online',
  description = 'Gaming, tabletop worlds, Roll20 mods, STO Info and podcasting projects.',
  responsiveImagePreloads = [],
} = Astro.props;

const siteName = 'MidNite Shadow Online';
const author = 'Steve Roberts';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://midniteshadow.online').href;
const imageAlt = `${siteName} — ${description}`;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? process.env.PUBLIC_GA_MEASUREMENT_ID ?? '';
const pageBackgroundVideoPolicy = getVideoLoadingPolicy('decorative');
const brandImagePolicy = getImageLoadingPolicy('brand');
const pathname = Astro.url.pathname;
const isActive = (href: string) => href === '/' ? pathname === '/' : pathname.startsWith(href);
const preloadLinks: ResponsivePreload[] = Array.isArray(responsiveImagePreloads)
  ? responsiveImagePreloads
  : [];
const debugProcessEnv = JSON.stringify(
  Object.fromEntries(Object.entries(process.env).filter(([k]) => k.startsWith('PUBLIC_'))),
  null, 2
);
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="debug-ga-id" content={gaId || 'EMPTY'} />
    <Fragment set:html={`<!-- ENV DEBUG (remove after confirming)
      gaId resolved: ${gaId || 'EMPTY'}
      process.env (PUBLIC_ only): ${debugProcessEnv}
    -->`} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="version" content={pkg.version} />
    <meta name="theme-color" content="#0a0a12" />
    <link rel="canonical" href={canonical} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/assets/images/hero_purple_embers.webp" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content="/assets/icons/android-chrome-512x512.png"
    />
    <meta name="twitter:image:alt" content={imageAlt} />
    <meta
      name="msapplication-config"
      content="/assets/icons/browserconfig.xml"
    />
    <link rel="icon" href="/assets/icons/favicon.ico" sizes="any" />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/assets/icons/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/assets/icons/favicon-16x16.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/assets/icons/apple-touch-icon.png"
    />
    <link
      rel="mask-icon"
      href="/assets/icons/safari-pinned-tab.svg"
      color="#6a0dad"
    />
    <link rel="manifest" href="/assets/icons/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&family=Marcellus+SC&family=Raleway:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
    />
    {
      preloadLinks.map((item) => (
        <link
          rel="preload"
          as="image"
          href={item.href}
          media={item.media}
          type={item.type}
          fetchpriority="high"
        />
      ))
    }
    <title>{title}</title>
  </head>
  <body>
    <video class="page-bg-video" autoplay muted loop playsinline aria-hidden="true" preload={pageBackgroundVideoPolicy.preload}>
      <source src="/assets/video/hero-purple-smoke.webm" type="video/webm" />
    </video>
    <div class="smoke-css" aria-hidden="true"></div>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">
            <Image
              class="brand-mark-icon"
              src={brandMarkIcon}
              loading={brandImagePolicy.loading}
              fetchpriority={brandImagePolicy.fetchpriority}
              decoding={brandImagePolicy.decoding}
              alt=""
            />
          </span>
          <span>MidNite Shadow Online</span>
        </a>
        <nav class="nav-links" aria-label="Primary navigation">
          <a href="/gaming/" aria-label="Gaming" aria-current={isActive('/gaming/') ? 'page' : undefined}><i class="fa-solid fa-gamepad" aria-hidden="true"></i> Gaming</a>
          <a href="/projects/sto-info/" aria-label="STO Info" aria-current={isActive('/projects/sto-info/') ? 'page' : undefined}><i class="fa-kit fa-sto-info" aria-hidden="true"></i> STO Info</a>
          <a href="/dnd/" aria-label="D and D" aria-current={isActive('/dnd/') ? 'page' : undefined}><i class="fa-solid fa-dice-d20" aria-hidden="true"></i> D&D</a>
          <a href="/projects/roll20-mods/" aria-label="Roll20 Mods" aria-current={isActive('/projects/roll20-mods/') ? 'page' : undefined}><i class="fa-solid fa-gears" aria-hidden="true"></i> Roll20 Mods</a>
          <a href="/projects/podcasting/" aria-label="Podcasting" aria-current={isActive('/projects/podcasting/') ? 'page' : undefined}><i class="fa-solid fa-microphone-lines" aria-hidden="true"></i> Podcasting</a>
          <a href="/posts/" aria-label="Posts" aria-current={isActive('/posts/') ? 'page' : undefined}><i class="fa-solid fa-newspaper" aria-hidden="true"></i> Posts</a>
        </nav>
        <button class="nav-toggle" aria-label="Open navigation" aria-expanded="false" aria-controls="mobile-nav">
          <i class="fa-solid fa-bars" aria-hidden="true"></i>
        </button>
      </div>
    </header>

    <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
      <div class="mobile-nav-panel">
        <div class="mobile-nav-top">
          <span class="mobile-nav-title">Menu</span>
          <button class="mobile-nav-close" aria-label="Close navigation">
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
        </div>
        <nav class="mobile-nav-links" aria-label="Mobile navigation">
          <a href="/gaming/" aria-label="Gaming" aria-current={isActive('/gaming/') ? 'page' : undefined}><i class="fa-solid fa-gamepad" aria-hidden="true"></i> Gaming</a>
          <a href="/projects/sto-info/" aria-label="STO Info" aria-current={isActive('/projects/sto-info/') ? 'page' : undefined}><i class="fa-kit fa-sto-info" aria-hidden="true"></i> STO Info</a>
          <a href="/dnd/" aria-label="D and D" aria-current={isActive('/dnd/') ? 'page' : undefined}><i class="fa-solid fa-dice-d20" aria-hidden="true"></i> D&D</a>
          <a href="/projects/roll20-mods/" aria-label="Roll20 Mods" aria-current={isActive('/projects/roll20-mods/') ? 'page' : undefined}><i class="fa-solid fa-gears" aria-hidden="true"></i> Roll20 Mods</a>
          <a href="/projects/podcasting/" aria-label="Podcasting" aria-current={isActive('/projects/podcasting/') ? 'page' : undefined}><i class="fa-solid fa-microphone-lines" aria-hidden="true"></i> Podcasting</a>
          <a href="/posts/" aria-label="Posts" aria-current={isActive('/posts/') ? 'page' : undefined}><i class="fa-solid fa-newspaper" aria-hidden="true"></i> Posts</a>
        </nav>
      </div>
    </div>
    <main><slot /></main>
    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <Image class="footer-icon" src={mns7RoundIcon} loading="lazy" decoding="async" alt="" width={96} height={96} />
          <div class="footer-col">
            <strong class="footer-site-name">MidNite Shadow Online</strong>
            <p class="footer-copy">&copy; {new Date().getFullYear()} MidNite Shadow Online</p>
          </div>
        </div>
        <div class="footer-nav-group">
          <nav class="footer-col footer-nav" aria-label="Pages">
            <a href="/" aria-current={isActive('/') ? 'page' : undefined}><i class="fa-solid fa-house" aria-hidden="true"></i> Home</a>
            <a href="/projects/" aria-current={isActive('/projects/') ? 'page' : undefined}><i class="fa-solid fa-diagram-project" aria-hidden="true"></i> Projects</a>
            <a href="/posts/" aria-current={isActive('/posts/') ? 'page' : undefined}><i class="fa-solid fa-newspaper" aria-hidden="true"></i> Posts</a>
          </nav>
          <nav class="footer-col footer-nav" aria-label="Info">
            <a href="/about/" aria-current={isActive('/about/') ? 'page' : undefined}><i class="fa-solid fa-circle-info" aria-hidden="true"></i> About</a>
            <a href="/privacy/" aria-current={isActive('/privacy/') ? 'page' : undefined}><i class="fa-solid fa-shield-halved" aria-hidden="true"></i> Privacy</a>
            {gaId && <a href="/privacy/#cookies" id="cookie-prefs-link"><i class="fa-solid fa-cookie-bite" aria-hidden="true"></i> Cookie Preferences</a>}
          </nav>
        </div>
      </div>
    </footer>
    {gaId && <CookieBanner gaId={gaId} />}
    <script is:inline src="https://kit.fontawesome.com/997e87a249.js" crossorigin="anonymous"></script>
    <script is:inline>
      (function () {
        var toggle = document.getElementById('mobile-nav') && document.querySelector('.nav-toggle');
        var panel = document.getElementById('mobile-nav');
        var closeBtn = panel && panel.querySelector('.mobile-nav-close');
        if (!toggle || !panel) return;

        function openMenu() {
          panel.classList.add('is-open');
          panel.setAttribute('aria-hidden', 'false');
          toggle.setAttribute('aria-expanded', 'true');
          toggle.querySelector('i').className = 'fa-solid fa-xmark';
          document.body.style.overflow = 'hidden';
        }

        function closeMenu() {
          panel.classList.remove('is-open');
          panel.setAttribute('aria-hidden', 'true');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.querySelector('i').className = 'fa-solid fa-bars';
          document.body.style.overflow = '';
        }

        toggle.addEventListener('click', openMenu);
        closeBtn.addEventListener('click', closeMenu);
        panel.addEventListener('click', function (e) {
          if (e.target === panel) closeMenu();
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeMenu();
        });

        var links = document.querySelectorAll('a[href]');
        links.forEach(function (link) {
          if (link.dataset.externalManaged === 'true') return;
          if (link.getAttribute('data-no-external') === 'true') return;
          var href = link.getAttribute('href');
          if (!href || href.startsWith('#')) return;

          var url;
          try {
            url = new URL(href, window.location.href);
          } catch {
            return;
          }

          var isWebLink = url.protocol === 'http:' || url.protocol === 'https:';
          var isExternal = isWebLink && url.origin !== window.location.origin;
          if (!isExternal) return;

          link.target = '_blank';
          link.rel = 'noopener noreferrer';
          link.classList.add('external-link');

          if (!link.querySelector('.external-link-icon')) {
            var icon = document.createElement('i');
            icon.className = 'fa-solid fa-arrow-up-right-from-square external-link-icon';
            icon.setAttribute('aria-hidden', 'true');
            link.appendChild(icon);
          }

          link.dataset.externalManaged = 'true';
        });
      })();
    </script>
  </body>
</html>
