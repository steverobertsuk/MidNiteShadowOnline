---
interface Props {
  title?: string;
}
const { title } = Astro.props;
---
<aside class="info-notice" role="note">
  <div class="info-notice-icon">
    <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
  </div>
  <div class="info-notice-body">
    {title && <p class="info-notice-title">{title}</p>}
    <slot />
  </div>
</aside>
