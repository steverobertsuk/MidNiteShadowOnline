---
import { Image } from 'astro:assets';
import placeholderImage from '../assets/images/placeholder.webp';
import { getImageLoadingPolicy, getVideoLoadingPolicy } from '../lib/mediaPriority';
import type { ImageMetadata } from 'astro';

interface HeroButton {
  label: string;
  href: string;
  icon?: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  video?: boolean;
  videoPoster?: string;
  image?: ImageMetadata;
  heroImage?: ImageMetadata;
  heroImageAlt?: string;
  tags?: string[];
  buttons?: HeroButton[];
}

const {
  eyebrow,
  title,
  lede,
  video = false,
  videoPoster = '/assets/images/hero_purple_embers.webp',
  image = placeholderImage,
  heroImage,
  heroImageAlt = '',
  tags = [],
  buttons = [],
} = Astro.props;
const heroImagePolicy = getImageLoadingPolicy('hero');
const heroVideoPolicy = getVideoLoadingPolicy('hero');
---

<section class="hero">
  {
    video ? (
      <video autoplay muted loop playsinline preload={heroVideoPolicy.preload} poster={videoPoster} src="/assets/video/hero-purple-embers.webm" />
    ) : (
      <Image
        class="hero-bg"
        src={image}
        alt=""
        loading={heroImagePolicy.loading}
        fetchpriority={heroImagePolicy.fetchpriority}
        decoding={heroImagePolicy.decoding}
      />
    )
  }
  <div class="container">
    <div class="hero-text">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {lede && <p class="lede">{lede}</p>}
      {tags.length > 0 && (
        <div class="meta">
          {tags.map((tag) => (
            <span class="tag"><i class="fa-solid fa-tag" aria-hidden="true"></i> {tag}</span>
          ))}
        </div>
      )}
      {buttons.length > 0 && (
        <div class="hero-actions">
          {buttons.map((btn) => (
            <a class="button" href={btn.href}>
              {btn.icon && <i class={btn.icon} aria-hidden="true"></i>} {btn.label}
            </a>
          ))}
        </div>
      )}
    </div>
    {heroImage && (
      <div class="hero-portrait">
        <Image
          src={heroImage}
          alt={heroImageAlt}
          loading={heroImagePolicy.loading}
          fetchpriority={heroImagePolicy.fetchpriority}
          decoding={heroImagePolicy.decoding}
        />
      </div>
    )}
  </div>
</section>
