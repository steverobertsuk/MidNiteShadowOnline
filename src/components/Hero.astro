---
import { Image } from 'astro:assets';
import placeholderImage from '../assets/images/placeholder.webp';
import { getImageLoadingPolicy, getVideoLoadingPolicy } from '../lib/mediaPriority';

const {
  eyebrow,
  title,
  lede,
  video = false,
  videoPoster = '/assets/images/hero_purple_embers.webp',
  image = placeholderImage,
} = Astro.props;
const heroImagePolicy = getImageLoadingPolicy('hero');
const heroVideoPolicy = getVideoLoadingPolicy('hero');
---

<section class="hero">
  {
    video ? (
      <video autoplay muted loop playsinline preload={heroVideoPolicy.preload} poster={videoPoster} src="/assets/video/hero-purple-embers.webm" />
    ) : (
      <Image
        class="hero-bg"
        src={image}
        alt=""
        loading={heroImagePolicy.loading}
        fetchpriority={heroImagePolicy.fetchpriority}
        decoding={heroImagePolicy.decoding}
      />
    )
  }
  <div class="container">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p class="lede">{lede}</p>
    <div class="hero-actions">
      <a class="button primary" href="/projects/"><i class="fa-solid fa-compass" aria-hidden="true"></i> Explore projects</a>
      <a class="button" href="/about/"><i class="fa-solid fa-user-astronaut" aria-hidden="true"></i> About MidNiteShadow</a>
    </div>
  </div>
</section>
