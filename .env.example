# Site URL used for canonical metadata and previews
PUBLIC_SITE_URL=https://midniteshadow.online

# Google Analytics 4 — Measurement ID (format: G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=

# Cloudflare Web Analytics — Beacon token
PUBLIC_CF_BEACON_TOKEN=

# Cloudflare Turnstile — public site key (safe to expose in HTML)
# Create a widget at https://dash.cloudflare.com -> Turnstile
PUBLIC_TURNSTILE_SITE_KEY=

# Contact form / server-side variables
# Keep secrets out of local .env files when possible.
# Configure these in your host/platform environment settings.
#
# PUBLIC_TURNSTILE_SECRET=
# PUBLIC_CONTACT_EMAIL=
# PUBLIC_FROM_EMAIL=
